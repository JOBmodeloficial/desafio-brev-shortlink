{
  "name": "@brevly/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/lib-storage": "^3",
    "@fastify/cors": "^10",
    "dotenv": "^16",
    "drizzle-orm": "^0.36",
    "fastify": "^5",
    "nanoid": "^5",
    "postgres": "^3",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^2",
    "drizzle-kit": "^0.28",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "prettier": "^3",
    "tsx": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^2"
  }
}
