# Porta da API
PORT=3333

# Conexão do Postgres (dev: serviço "db" do docker-compose)
DATABASE_URL=postgresql://brevly:brevly@localhost:5432/brevly

# Cloudflare R2 (S3-compatible) — necessário para o export de CSV em produção
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ACCESS_KEY_ID=""
CLOUDFLARE_SECRET_ACCESS_KEY=""
CLOUDFLARE_BUCKET=""
CLOUDFLARE_PUBLIC_URL=""

# Driver de storage (opcional): r2 (padrão) | stub (dev/E2E — não sobe ao R2)
# STORAGE_DRIVER=r2
